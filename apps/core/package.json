  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "docker:build": "docker compose -f ../../docker-compose.yml build core",
    "docker:up": "docker compose -f ../../docker-compose.yml up -d core",
    "docker:logs": "docker compose -f ../../docker-compose.yml logs -f core",
    "dev": "pnpm docker:up && pnpm docker:logs",
    "dev:local": "node --import=tsx --watch --no-warnings --env-file=.env.dev src/server.ts",
    "build": "tsc --noEmit",
    "tsc": "tsc --noEmit",
    "start": "node --import=tsx --env-file=.env.prod src/server.ts",
    "test": "vitest",
    "test:watch": "vitest watch"
  },
