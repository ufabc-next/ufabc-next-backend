{
  "extends": "fastify-tsconfig",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "module": "es2022",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "exclude": ["node_modules/**/*"]
}
