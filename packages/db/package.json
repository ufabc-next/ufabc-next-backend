{
  "name": "@next/db",
  "version": "1.0.0",
  "description": "Database models and queries for UFABC Next backend",
  "type": "module",
  "exports": {
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./src/models.ts"
    },
    "./queries": {
      "types": "./dist/queries.d.ts",
      "import": "./src/queries.ts"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./src/client.ts"
    }
  },
  "scripts": {
    "build": "tsgo",
    "tsc": "tsgo --noEmit",
    "check-types": "tsgo --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules"
  },
  "dependencies": {
    "fastify": "catalog:",
    "mongoose": "catalog:"
  },
  "devDependencies": {
    "@next/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "fastify": "catalog:",
    "fastify-plugin": "catalog:",
    "@typescript/native-preview": "catalog:",
    "typescript": "catalog:"
  }
}
